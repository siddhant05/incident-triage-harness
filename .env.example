# Copy to .env (gitignored) and fill in. Used locally; on Render set via dashboard.

# Primary agent: gemini | claude | heuristic
HARNESS_AGENT=gemini

# Required for LLM agents
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Git context source
GITHUB_REPO=psf/requests
# GITHUB_TOKEN=    # optional, raises GitHub REST rate limit to 5000/hr
# DEMO_GIT_REPO=./demo-repo  # local clone fallback

# Slack incoming webhook (incident notifications)
SLACK_WEBHOOK_URL=
